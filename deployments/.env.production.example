# Production Environment Configuration
# Copy this file to .env.production and fill in all values
# Usage: docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d

# =============================================================================
# Database
# =============================================================================
POSTGRES_PASSWORD=<generate-strong-password>
TSM_DATABASE_HOST=postgres
TSM_DATABASE_PORT=5432
TSM_DATABASE_NAME=tsm
TSM_DATABASE_USER=tsm
TSM_DATABASE_PASSWORD=<same-as-POSTGRES_PASSWORD>
TSM_DATABASE_SSL_MODE=disable

# =============================================================================
# Server
# =============================================================================
TSM_SERVER_HOST=0.0.0.0
TSM_SERVER_PORT=8080

# =============================================================================
# Security (REQUIRED - generate strong values)
# =============================================================================
# Generate with: openssl rand -hex 32
TSM_JWT_SECRET=<generate-with-openssl-rand-hex-32>

# Must be exactly 32 bytes for AES-256
# Generate with: openssl rand -hex 16
ENCRYPTION_KEY=<32-byte-key-for-aes-256>

# =============================================================================
# Storage
# =============================================================================
TSM_STORAGE_DEFAULT_BACKEND=local
TSM_STORAGE_LOCAL_BASE_PATH=/app/data

# Uncomment for S3 storage:
# TSM_STORAGE_DEFAULT_BACKEND=s3
# TSM_STORAGE_S3_REGION=us-east-1
# TSM_STORAGE_S3_BUCKET=terraform-state-manager
# TSM_STORAGE_S3_ACCESS_KEY_ID=<your-access-key>
# TSM_STORAGE_S3_SECRET_ACCESS_KEY=<your-secret-key>

# Uncomment for Azure Blob storage:
# TSM_STORAGE_DEFAULT_BACKEND=azure
# TSM_STORAGE_AZURE_ACCOUNT_NAME=<your-account>
# TSM_STORAGE_AZURE_ACCOUNT_KEY=<your-key>
# TSM_STORAGE_AZURE_CONTAINER_NAME=terraform-state-manager

# Uncomment for GCS storage:
# TSM_STORAGE_DEFAULT_BACKEND=gcs
# TSM_STORAGE_GCS_BUCKET=terraform-state-manager
# TSM_STORAGE_GCS_CREDENTIALS_JSON=<your-credentials-json>

# =============================================================================
# Authentication
# =============================================================================
# Uncomment for OIDC:
# TSM_AUTH_OIDC_ENABLED=true
# TSM_AUTH_OIDC_ISSUER_URL=https://your-provider.com
# TSM_AUTH_OIDC_CLIENT_ID=<your-client-id>
# TSM_AUTH_OIDC_CLIENT_SECRET=<your-client-secret>
# TSM_AUTH_OIDC_REDIRECT_URL=https://tsm.yourdomain.com/callback

# =============================================================================
# Logging
# =============================================================================
TSM_LOGGING_LEVEL=warn
TSM_LOGGING_FORMAT=json
